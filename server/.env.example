# Credenciais AppBarber
APPBARBER_EMAIL=
APPBARBER_PASSWORD=

# Webhook para envio de cookies
WEBHOOK_URL=

# Intervalo de atualizacao em horas (login completo + webhook)
REFRESH_INTERVAL=4

# Fuso horario
TZ=America/Sao_Paulo

# Porta do servidor HTTP (health check)
PORT=3000

# URL publica (para EasyPanel, colocar o dominio atribuido)
PUBLIC_URL=
