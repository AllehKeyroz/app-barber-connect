# Credenciais AppBarber
APPBARBER_EMAIL=
APPBARBER_PASSWORD=

# Webhook para envio de cookies
WEBHOOK_URL=

# Intervalo de verificacao em minutos (leve - so checa cookies, sem navegar)
VERIFY_INTERVAL=60

# Intervalo de refresh forcado em minutos (navegacao completa na pagina)
REFRESH_INTERVAL=360

# Porta do servidor HTTP (health check)
PORT=3000

# URL publica (para EasyPanel, colocar o dominio atribuido)
PUBLIC_URL=
